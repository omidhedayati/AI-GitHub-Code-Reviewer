# PostgreSQL
POSTGRES_USER=reviewer
POSTGRES_PASSWORD=reviewer
POSTGRES_DB=reviewer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+psycopg://reviewer:reviewer@postgres:5432/reviewer
JWT_SECRET=change-me-in-production
DEBUG=false
APP_NAME=AI GitHub Code Reviewer
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama (used in later steps)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Repository cloning
REPOS_WORKSPACE_ROOT=./.repos
GIT_CLONE_DEPTH=1
GIT_CLONE_TIMEOUT_SECONDS=300
